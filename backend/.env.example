PORT=8080
BASE_URL=http://localhost:8080

# MongoDB (default db name: food_rush)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=food_rush

# Optional: set SEED_DEMO_DATA=true — automatic demo seed is disabled on MongoDB; use app/API instead

# PayPal (use sandbox first)
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
